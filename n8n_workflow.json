// 2. Fetch the sharp executive text from Node 3 (AI Agent)
const aiInsights = $input.first().json.output;

// 3. Dynamically loop through the top products/categories to build a clean HTML leaderboard list
let leaderboardHtml = '';
for (const [itemName, revenue] of Object.entries(leaderboard)) {
