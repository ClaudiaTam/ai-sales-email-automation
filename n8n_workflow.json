        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
            <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 20px; border-radius: 8px;">
                <div style="font-size: 11px; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Gross Settled Revenue</div>
                <div style="font-size: 24px; color: #4f46e5; font-weight: 800; margin-top: 4px;">$${snapshot.total_revenue.toLocaleString(undefined, {minimumFractionDigits: 2})}</div>
