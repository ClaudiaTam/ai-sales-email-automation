        <span style="color: #475569; font-weight: 600;">📦 Product Line: ${itemName}</span>
        <strong style="color: #0f172a;">$${revenue.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</strong>
    </div>
    `;
}

